# Committed (not secret) — GitHub Pages needs the basePath baked in at build time.
# This MUST match the repo name exactly (GitHub serves project sites at
# https://<user>.github.io/<repo-name>/). The repo is currently "Personal-Site".
# If you rename the repo, update this to the new slug or all CSS/JS will 404.
NEXT_PUBLIC_BASE_PATH=/Personal-Site
