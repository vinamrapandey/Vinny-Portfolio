# Committed (not secret) — GitHub Pages needs the basePath baked in at build time.
# This MUST match the repo name exactly (GitHub serves project sites at
# https://<user>.github.io/<repo-name>/). The repo is named "Vinny-Portfolio".
# If you rename the repo again, update this to the new slug or all CSS/JS will 404.
NEXT_PUBLIC_BASE_PATH=/Vinny-Portfolio
