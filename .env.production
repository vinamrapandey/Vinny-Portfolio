# Committed (not secret) — GitHub Pages needs the basePath baked in at build time.
# TODO: update this if the repo's final slug differs from "Vinny-Dev-Portfolio"
# (GitHub auto-converts spaces in the repo name to hyphens).
NEXT_PUBLIC_BASE_PATH=/Vinny-Dev-Portfolio

# Web3Forms access keys are public by design (like a site key), safe to commit.
# TODO: replace with your real key from https://web3forms.com before launch.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=YOUR_WEB3FORMS_ACCESS_KEY
